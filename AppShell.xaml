<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HealthKeeper.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HealthKeeper"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">
    <TabBar>
        <Tab Title="Daily Tracker">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="💊" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate local:DailyTrackerPage}" />
        </Tab>

        <Tab Title="Symptom Log">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="📄" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate local:SymptomLogPage}" />
        </Tab>

        <Tab Title="Emergency Card">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="🤍" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate local:EmergencyCardPage}" />
        </Tab>
    </TabBar>

</Shell>
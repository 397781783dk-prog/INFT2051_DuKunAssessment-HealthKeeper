<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthKeeper.SymptomLogPage"
             BackgroundColor="#F8F9FA">

    <Grid>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout>
                    <Label Text="Symptom Log" FontSize="24" FontAttributes="Bold" TextColor="#111827" />
                    <Label Text="Track Your Health" FontSize="14" TextColor="#6B7280" />
                </VerticalStackLayout>
                <Border Grid.Column="1" Stroke="#D1D5DB" StrokeThickness="1" VerticalOptions="Start" Padding="8,4">
                    <Label Text="文A 中" FontSize="12" TextColor="#111827" />
                </Border>
            </Grid>

            <Border IsVisible="{Binding HasNoRecords}" 
                    Stroke="#D1D5DB" StrokeThickness="1" StrokeDashArray="5,5" BackgroundColor="Transparent" HeightRequest="200" Margin="0,20,0,0">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="📋" FontSize="30" HorizontalOptions="Center"/>
                    <Label Text="No Records" FontSize="16" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="Center" />
                    <Label Text="Tap + button to add" FontSize="12" TextColor="#9CA3AF" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding Symptoms}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="#D1D5DB" StrokeThickness="1" BackgroundColor="White" Padding="15" Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*, Auto">

                                <Label Text="{Binding .}" FontSize="16" TextColor="#111827" VerticalOptions="Center" />

                                <Button Grid.Column="1" 
                                        Text="❌" 
                                        BackgroundColor="Transparent" 
                                        TextColor="Red"
                                        Padding="0"
                                        Clicked="OnDeleteButtonClicked"
                                        CommandParameter="{Binding .}" />

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <Button Text="+" 
                Clicked="OnAddButtonClicked"
                FontSize="24" 
                TextColor="White" 
                BackgroundColor="#0F172A" 
                CornerRadius="30" 
                WidthRequest="60" 
                HeightRequest="60" 
                HorizontalOptions="End" 
                VerticalOptions="End" 
                Margin="20" />
    </Grid>
</ContentPage>